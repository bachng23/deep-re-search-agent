# Required
# Used by the configured LLM provider/router.
API_KEY=

# Optional model selection.
# Leave unset to let the app choose per node.
# MODEL_TIER_OVERRIDE=fast
# MODEL_TIER_OVERRIDE=balanced
# MODEL_TIER_OVERRIDE=reasoning

# Optional model names.
FAST_MODEL=deepseek/deepseek-v4-flash
BALANCED_MODEL=deepseek/deepseek-v4-pro
REASONING_MODEL=deepseek/deepseek-v4-pro

# Optional tool limits/timeouts.
ARXIV_MAX_RESULTS=8
SEMANTIC_SCHOLAR_MAX_RESULTS=8
REQUEST_TIMEOUT_SECONDS=20

# Optional Semantic Scholar API key.
# Without this key, Semantic Scholar may rate-limit more aggressively.
SEMANTIC_SCHOLAR_API_KEY=

# Optional LangSmith tracing.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=paper-research-agent
